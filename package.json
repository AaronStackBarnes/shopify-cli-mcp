  "author": "Gabriel Reeves <gabriel@meridiancommerce.dev>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/gbrlxvii/shopify-cli-mcp"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  }
}
