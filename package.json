{
  "name": "@gbrlxvii/shopify-cli-mcp",
  "version": "0.3.0",
  "description": "MCP server that wraps the Shopify CLI for AI-powered app and theme development",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "shopify-cli-mcp": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "shopify",
    "cli",
    "mcp",
    "model-context-protocol",
    "ai",
    "development",
    "shopify-app",
